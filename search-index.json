4]]}}}],["tip",{"_index":10,"t":{"9":{"position":[[0,4]]}}}],["vs",{"_index":17,"t":{"24":{"position":[[21,2]]}}}]],"pipeline":["stemmer"]}},{"documents":[{"i":1,"t":"Multi-stage builds let you compile inside Docker and ship only what the app actually needs — no build tools in production.","s":"Shrink your Docker images with multi-stage builds","u":"/knowledgebase/blog/2026/05/20/docker-multi-stage-builds","p":1},{"i":11,"t":"Java 16 added Stream.toList() — but it's not a drop-in replacement for Collectors.toList().","s":"TIL: Stream.toList() vs Collectors.toList() in Java","u":"/knowledgebase/blog/2026/05/22/til-stream-tolist-vs-collectors-tolist","p":11},{"i":21,"t":"Archive","s":"","u":"/knowledgebase/blog/archive","p":21}],"index":{"version":"2.3.9","fields":["t"],"fieldVectors":[["t/1",[0,0.751,1,0.751,2,1.114,3,0.751,4,0.751,5,0.751,6,0.751,7,0.751,8,0.751,9,0.751,10,0.36,11,0.751,12,0.751]],["t/11",[10,0.447,13,0.933,14,0.933,15,0.933,16,0.933,17,0.933,18,0.933,19,0.933,20,0.933]],["t/21",[21,1.528]]],"invertedIndex":[["",{"_index":10,"t":{"1":{"position":[[91,1]]},"11":{"position":[[30,1]]}}}],["16",{"_index":14,"t":{"11":{"position":[[5,2]]}}}],["actual",{"_index":8,"t":{"1":{"position":[[76,8]]}}}],["ad",{"_index":15,"t":{"11":{"position":[[8,5]]}}}],["app",{"_index":7,"t":{"1":{"position":[[72,3]]}}}],["archiv",{"_index":21,"t":{"21":{"position":[[0,7]]}}}],["build",{"_index":2,"t":{"1":{"position":[[12,6],[96,5]]}}}],["collectors.tolist",{"_index":20,"t":{"11":{"position":[[71,20]]}}}],["compil",{"_index":3,"t":{"1":{"position":[[27,7]]}}}],["docker",{"_index":5,"t":{"1":{"position":[[42,6]]}}}],["drop",{"_index":18,"t":{"11":{"position":[[47,4]]}}}],["insid",{"_index":4,"t":{"1":{"position":[[35,6]]}}}],["it'",{"_index":17,"t":{"11":{"position":[[36,4]]}}}],["java",{"_index":13,"t":{"11":{"position":[[0,4]]}}}],["multi",{"_index":0,"t":{"1":{"position":[[0,5]]}}}],["need",{"_index":9,"t":{"1":{"position":[[85,5]]}}}],["product",{"_index":12,"t":{"1":{"position":[[111,11]]}}}],["replac",{"_index":19,"t":{"11":{"position":[[55,11]]}}}],["ship",{"_index":6,"t":{"1":{"position":[[53,4]]}}}],["stage",{"_index":1,"t":{"1":{"position":[[6,5]]}}}],["stream.tolist",{"_index":16,"t":{"11":{"position":[[14,15]]}}}],["tool",{"_index":11,"t":{"1":{"position":[[102,5]]}}}]],"pipeline":["stemmer"]}},{"documents":[],"index":{"version":"2.3.9","fields":["t"],"fieldVectors":[],"invertedIndex":[],"pipeline":["stemmer"]}},{"documents":[{"i":2,"t":"Build tools, test dependencies, and intermediate artifacts have no business being in your production image. Multi-stage builds solve this cleanly.","s":"Shrink your Docker images with multi-stage builds","u":"/knowledgebase/blog/2026/05/20/docker-multi-stage-builds","h":"","p":1},{"i":4,"t":"A naive Dockerfile that installs Maven, compiles a Spring Boot app, and runs it ends up with Maven, the JDK, and all your source code in the final image — easily 600–800 MB. # single-stage — too much in the final image FROM eclipse-temurin:21 WORKDIR /app COPY . . RUN ./mvnw package -DskipTests CMD [\"java\", \"-jar\", \"target/app.jar\"]","s":"The problem with single-stage builds","u":"/knowledgebase/blog/2026/05/20/docker-multi-stage-builds","h":"#the-problem-with-single-stage-builds","p":1},{"i":6,"t":"# Stage 1: compile FROM eclipse-temurin:21 AS build WORKDIR /app COPY pom.xml . COPY src ./src RUN ./mvnw package -DskipTests # Stage 2: run — just the JRE and the jar FROM eclipse-temurin:21-jre AS runtime WORKDIR /app COPY --from=build /app/target/app.jar app.jar EXPOSE 8080 ENTRYPOINT [\"java\", \"-jar\", \"app.jar\"] The --from=build instruction copies only what you explicitly ask for from the build stage. Docker discards everything else.","s":"Multi-stage: build in one image, run from another","u":"/knowledgebase/blog/2026/05/20/docker-multi-stage-builds","h":"#multi-stage-build-in-one-image-run-from-another","p":1},{"i":8,"t":"Approach Image size Single-stage (JDK + Maven + source) ~750 MB Multi-stage (JRE only) ~230 MB Smaller image = faster pulls, smaller attack surface, less to scan for vulnerabilities.","s":"Result","u":"/knowledgebase/blog/2026/05/20/docker-multi-stage-builds","h":"#result","p":1},{"i":10,"t":"Name your stages (AS build, AS runtime) so --from= is readable Cache the dependency download layer separately by copying pom.xml before src/ — Maven will skip re-downloading if pom.xml hasn't changed Use a distroless or Alpine JRE for even smaller images Have a Docker tip? Write a TIL or article and share it with the team.","s":"Tips","u":"/knowledgebase/blog/2026/05/20/docker-multi-stage-builds","h":"#tips","p":1},{"i":12,"t":"Java 16 introduced Stream.toList() as a shorter way to collect a stream into a list. Looks like a simple convenience method — turns out there's a meaningful difference.","s":"TIL: Stream.toList() vs Collectors.toList() in Java","u":"/knowledgebase/blog/2026/05/22/til-stream-tolist-vs-collectors-tolist","h":"","p":11},{"i":14,"t":"I was simplifying some stream pipelines and swapped collect(Collectors.toList()) for the newer Stream.toList(). Tests started failing with UnsupportedOperationException. Not obvious why at first.","s":"Context","u":"/knowledgebase/blog/2026/05/22/til-stream-tolist-vs-collectors-tolist","h":"#context","p":11},{"i":16,"t":"Stream.toList() returns an unmodifiable list. Collectors.toList() returns a regular mutable ArrayList. // Collectors.toList() — mutable, you can add/remove after List<String> mutable = stream.collect(Collectors.toList()); mutable.add(\"extra\"); // fine // Stream.toList() — unmodifiable List<String> immutable = stream.toList(); immutable.add(\"extra\"); // throws UnsupportedOperationException Collectors.toUnmodifiableList() existed before Java 16 and gives the same behaviour as Stream.toList() — so the new method is really a shorthand for the unmodifiable version, not the mutable one.","s":"The discovery","u":"/knowledgebase/blog/2026/05/22/til-stream-tolist-vs-collectors-tolist","h":"#the-discovery","p":11},{"i":18,"t":"If you're collecting into a list you then mutate (sorting in place, removing elements, etc.), the new shorthand will break. The fix is straightforward — use Collectors.toList() when you need mutability, Stream.toList() when you don't — but the failure mode is a runtime exception, not a compile error. Prefer Stream.toList() by default (immutability is usually the right default), and reach for Collectors.toList() only when you need to mutate the result.","s":"Why it matters","u":"/knowledgebase/blog/2026/05/22/til-stream-tolist-vs-collectors-tolist","h":"#why-it-matters","p":11},{"i":20,"t":"JDK-8180352 — the JEP that introduced Stream.toList() Java 16 release notes","s":"Source","u":"/knowledgebase/blog/2026/05/22/til-stream-tolist-vs-collectors-tolist","h":"#source","p":11},{"i":25,"t":"May 22, 2026 · 2 min read Kavinda Dewmith Software Engineer","s":"TIL: Stream.toList() vs Collectors.toList() in Java","u":"/knowledgebase/blog/authors/kavinda","h":"","p":23}],"index":{"version":"2.3.9","fields":["t"],"fieldVectors":[["t/2",[0,1.96,1,2.591,2,1.955,3,1.955,4,2.591,5,2.591,6,2.591,7,2.591,8,2.591,9,1.222,10,1.955,11,0.972,12,2.591,13,2.591]],["t/4",[9,1.177,11,0.644,14,1.716,15,1.716,16,1.716,17,1.479,18,1.017,19,1.716,20,1.716,21,1.883,22,1.883,23,1.716,24,1.716,25,1.017,26,1.295,27,1.716,28,2.496,29,0.402,30,1.716,31,1.716,32,1.295,33,1.295,34,1.716,35,1.295,36,1.295,37,1.295,38,1.017,39,1.295,40,1.295,41,1.295,42,1.716,43,0.644,44,1.295,45,1.716]],["t/6",[0,1.374,11,1.041,18,0.921,21,1.75,22,1.75,29,0.37,35,1.75,36,1.75,37,1.75,38,1.824,39,1.172,40,1.172,41,1.172,43,0.583,44,1.75,46,1.553,47,1.172,48,1.75,49,1.172,50,1.374,51,0.921,52,2.319,53,1.553,54,2.319,55,1.553,56,1.553,57,1.553,58,1.553,59,1.553,60,1.553,61,1.172,62,1.553,63,1.553]],["t/8",[9,1.362,10,1.591,11,1.083,17,1.25,25,1.25,26,1.591,29,0.37,32,2.178,33,1.591,50,1.25,64,2.109,65,2.109,66,2.109,67,2.109,68,2.178,69,2.109,70,2.109,71,2.109,72,2.109,73,2.109,74,2